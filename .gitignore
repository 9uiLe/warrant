# ビルド成果物（`go build` で root に出る単一バイナリ。配布物は CI でビルドする）
/warrant
/dist/
*.exe

# Go のテスト・カバレッジ出力
*.test
*.out
coverage.txt

# warrant 自身の派生データ（判断の根拠にしない・SSOT から再生成可能）
*.generated.*
.warrant/*.generated.*

# ADR のレビュー用 HTML と共有アセット（正本は Markdown。`ema gen` で再生成可能な派生物）
docs/decisions/*.html
docs/decisions/assets/

# fusion(マルチエージェント設計レビュー)の作業成果物（派生物・再生成可能）
ai/fusion/

# OS / エディタ
.DS_Store
*.swp
